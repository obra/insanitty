+    // insanitty: a GTK-apprt embedding library exposing a small C ABI so a host
+    // GTK4 app can host Ghostty's Application + create live terminal surfaces.
+    // Gated on -Dinsanitty-lib so the normal builds are untouched.
+    if (b.option(bool, "insanitty-lib", "Build the insanitty GTK embedding lib") orelse false) {
+        // shim_cfg inherits -Dapp-runtime=gtk from the CLI; apprt.zig maps a
+        // gtk-app-runtime library to the real GTK apprt (not embedded/Metal).
+        const shim_cfg = config;
+        const shim_deps = try buildpkg.SharedDeps.init(b, &shim_cfg);
+        const shim = b.addLibrary(.{
+            .name = "ghostty-gtk",
+            .linkage = .dynamic,
+            .root_module = b.createModule(.{
+                .root_source_file = b.path("src/insanitty_c_api.zig"),
+                .target = shim_cfg.target,
+                .optimize = shim_cfg.optimize,
+            }),
+            // Self-hosted x86_64 backend crashes on Ghostty (see GhosttyExe.zig).
+            .use_llvm = true,
+        });
+        _ = try shim_deps.add(shim);
+        b.installArtifact(shim);
+        b.getInstallStep().dependOn(&b.addInstallHeaderFile(
+            b.path("include/insanitty.h"),
+            "insanitty.h",
+        ).step);
+    }
+
     // macOS only artifacts. These will error if they're initialized for
     // other targets. In lib-vt mode emit_xcframework controls the lib-vt
     // xcframework above, not this one.
